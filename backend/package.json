{
  "name": "tensor-backend",
  "version": "1.0.0",
  "description": "Enterprise-grade backend system for Tensor School ERP",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand",
