    "test:integration": "jest --testPathPattern=tests/integration --runInBand",
    "test:property": "jest --testPathPattern=tests/property --runInBand",
    "test:coverage": "jest --coverage --runInBand"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.8.0",
    "joi": "^17.9.0",
    "jsonwebtoken": "^9.0.2",
    "node-cache": "^5.1.2",
    "swagger-jsdoc": "^6.2.0",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.10.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "fast-check": "^3.12.0",
    "jest": "^29.6.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
